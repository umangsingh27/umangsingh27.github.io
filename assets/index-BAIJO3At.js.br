:"Both Spectro Pro and Optimise launched with minimal UI — functional, fast, and honest about being a beta. Getting to 5 customers with an imperfect product was worth more than delaying for visual refinement."})]})]}),(0,p.jsxs)("div",{className:"learning-point fade-up-child",children:[(0,p.jsx)("div",{className:"learning-point__number",children:"3"}),(0,p.jsxs)("div",{className:"learning-point__content",children:[(0,p.jsx)("h3",{children:"Real metrics are earned, not assumed."}),(0,p.jsx)("p",{children:"The 20% and 12% cost saving opportunities weren't marketing estimates — they came from timing actual heats, counting actual heats per day, and doing the arithmetic with real foundry operators. Designing from those numbers gave the product credibility that no amount of beautiful UI could provide."})]})]})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsx)("div",{className:"case-section__inner",children:(0,p.jsxs)("div",{className:"next-project",children:[(0,p.jsx)("span",{className:"next-project__label",children:"NEXT CASE STUDY"}),(0,p.jsx)(c,{to:"/work/nowpurchase-website",className:"next-project__link",children:"NowPurchase Website Revamp →"})]})})})]})}function S(){return(0,d.useEffect)(()=>{document.title="NowPurchase Website Revamp — Umang Singh"},[]),x(),v(.1),(0,p.jsxs)("main",{className:"nowpurchase-case-study",children:[(0,p.jsx)("section",{className:"case-hero fade-up",children:(0,p.jsxs)("div",{className:"case-hero__inner",children:[(0,p.jsx)("span",{className:"case-hero__tag",children:"WEBSITE · GROWTH"}),(0,p.jsx)("h1",{children:"NowPurchase Website Revamp"}),(0,p.jsx)("p",{className:"case-hero__subtitle",children:"A full end-to-end redesign of a B2B procurement platform's website — grounded in data, stakeholder research, and a clear content strategy that doubled organic reach."}),(0,p.jsxs)("div",{className:"case-metadata-grid",children:[(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"My Role"}),(0,p.jsx)("p",{children:"Project Head & User Experience Designer"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Team"}),(0,p.jsx)("p",{children:"3 Members"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Timeline"}),(0,p.jsx)("p",{children:"April 1 – April 30, 2023"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Tools"}),(0,p.jsx)("p",{children:"Clickup · Miro · Microsoft Clarity · Google Analytics · Amplitude · Figma"})]})]}),(0,p.jsx)("div",{className:"case-hero__visual",children:(0,p.jsx)(f,{src:"/images/nowpurchase-website/hero_image.png",alt:"NowPurchase website revamp — hero section design",className:"case-visual case-visual--hero",priority:!0})})]})}),(0,p.jsx)("section",{className:"case-section case-section--dark context-dark fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{className:"context-heading",children:"NowPurchase had outgrown its own website."}),(0,p.jsxs)("div",{className:"context-body",children:[(0,p.jsx)("p",{className:"context-paragraph",children:"NowPurchase — a B2B company digitising India's $19B foundry industry — had built significant credibility with enterprise clients through MetalCloud, its SaaS platform. But its public website still spoke the language of an early-stage startup: vague, jargon-heavy, and unclear about what the company actually did. Four things were consistently failing visitors: users were confused about what the business did, technical jargon made content inaccessible, navigation was unclear, and company culture and investor credibility were invisible."}),(0,p.jsx)("p",{className:"context-paragraph",children:"The ask was simple but demanding: a complete website redesign in 30 days. One designer leading the project. Me."}),(0,p.jsx)("p",{className:"context-paragraph",children:"That constraint — one month, one person, complete overhaul — became the thing that forced clarity. We couldn't afford to redesign for complexity. We had to redesign for understanding."}),(0,p.jsxs)("figure",{className:"case-figure case-figure--full",style:{marginTop:"2rem"},children:[(0,p.jsx)(f,{src:"/images/nowpurchase-website/existing-website.png",alt:"NowPurchase existing website before revamp",className:"case-visual case-visual--screenshot"}),(0,p.jsx)("figcaption",{children:"The existing NowPurchase website — before the revamp"})]})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"Three research methods. One clear picture."}),(0,p.jsx)("div",{className:"case-body",children:(0,p.jsx)("p",{children:"Before touching Figma, I spent the first week doing three things: analysing how the current site was actually being used, understanding what competitors were doing better, and getting strategic clarity from the people who knew the business best."})}),(0,p.jsxs)("div",{className:"research-grid",children:[(0,p.jsxs)("div",{className:"research-block fade-up-child",children:[(0,p.jsx)("span",{className:"research-label",children:"DATA ANALYSIS"}),(0,p.jsx)("h3",{children:"30-Day Heatmap & Session Recording Analysis"}),(0,p.jsxs)("p",{className:"research-tool",children:[(0,p.jsx)("strong",{children:"Tool:"})," Microsoft Clarity"]}),(0,p.jsx)("p",{className:"research-desc",children:"Studied 30 days of heatmap data and session recordings to understand exactly where users were clicking, scrolling, hesitating, and dropping off on the existing site. No assumptions — only observed behaviour."}),(0,p.jsxs)("p",{className:"research-finding",children:[(0,p.jsx)("strong",{children:"Key findings:"}),' Users were scrolling past the hero without engaging. The MetalCloud section was being ignored despite being the company\'s core product. The "Why NowPurchase" section had near-zero interaction.']}),(0,p.jsxs)("div",{className:"case-image-row",style:{marginTop:"1.5rem",display:"grid",gridTemplateColumns:"repeat(4, 1fr)",gap:"12px"},children:[(0,p.jsx)(f,{src:"/images/nowpurchase-website/heatmap-1.png",alt:"Heatmap — Hero section",className:"case-visual case-visual--heatmap"}),(0,p.jsx)(f,{src:"/images/nowpurchase-website/heatmap-2.png",alt:"Heatmap — Careers section",className:"case-visual case-visual--heatmap"}),(0,p.jsx)(f,{src:"/images/nowpurchase-website/heatmap-3.png",alt:"Heatmap — MetalCloud section",className:"case-visual case-visual--heatmap"}),(0,p.jsx)(f,{src:"/images/nowpurchase-website/heatmap-4.png",alt:"Heatmap — Footer",className:"case-visual case-visual--heatmap"})]})]}),(0,p.jsxs)("div",{className:"research-block fade-up-child",children:[(0,p.jsx)("span",{className:"research-label",children:"COMPETITIVE ANALYSIS"}),(0,p.jsx)("h3",{children:"Benchmarking Against 6 Competitors"}),(0,p.jsxs)("p",{className:"research-tool",children:[(0,p.jsx)("strong",{children:"Competitors studied:"})," Zetwerk · Grainmart · IndiaMART · BlazerCart · Gravio · and others"]}),(0,p.jsx)("p",{className:"research-desc",children:"Evaluated how trusted B2B procurement platforms structured their messaging, navigation, and social proof. Identified patterns that built credibility and patterns that created confusion."}),(0,p.jsxs)("p",{className:"research-finding",children:[(0,p.jsx)("strong",{children:"Key finding:"})," The best-performing B2B procurement sites led with outcomes (what you gain), not features (what we offer). NowPurchase's site was doing the opposite."]})]}),(0,p.jsxs)("div",{className:"research-block fade-up-child",children:[(0,p.jsx)("span",{className:"research-label",children:"STAKEHOLDER INTERVIEWS"}),(0,p.jsx)("h3",{children:"12 Strategic Priorities, One Framework"}),(0,p.jsxs)("p",{className:"research-tool",children:[(0,p.jsx)("strong",{children:"Framework used:"})," Why-How-What"]}),(0,p.jsx)("p",{className:"research-desc",children:"Conducted structured interviews with NowPurchase stakeholders using the Why-How-What framework to understand the company's goals, how it delivers value, and what it wants to be known for."}),(0,p.jsxs)("p",{className:"research-finding",children:[(0,p.jsx)("strong",{children:"12 priorities emerged"})," — including: invest in technology to streamline procurement, provide superior service to become a trusted platform, digitise operations, expand to 200+ clients, and overcome the perception that cloud-based procurement is unreliable."]}),(0,p.jsxs)("figure",{className:"case-figure",style:{marginTop:"1.5rem"},children:[(0,p.jsx)(f,{src:"/images/nowpurchase-website/stakeholder-interview.png",alt:"Stakeholder interview session with NowPurchase leadership",className:"case-visual"}),(0,p.jsx)("figcaption",{children:"Stakeholder interview session — NowPurchase leadership"})]})]})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--bg fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"The site was speaking to itself. Not to its visitors."}),(0,p.jsxs)("div",{className:"case-body",children:[(0,p.jsx)("p",{children:'The research painted a consistent picture: NowPurchase\'s website was written by people who deeply understood the business, for people who already understood it. Technical terms like "ChargeMix," "heat," and "spectrometer" appeared without explanation. The two distinct offerings — a procurement marketplace and a SaaS platform — were presented as one undifferentiated product.'}),(0,p.jsx)("p",{children:"The opportunity: if we could make the website explain itself in plain language, structured around what visitors actually needed to know, NowPurchase could convert significantly more of the right traffic."})]}),(0,p.jsx)("blockquote",{className:"insight-callout",children:'"The problem wasn\'t the design. It was the content strategy. Fix that first — then design around it."'})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"Two brands inside one company. Both needed their own voice."}),(0,p.jsx)("div",{className:"case-body",children:(0,p.jsx)("p",{children:"During brainstorming sessions with the team, we identified that NowPurchase was actually two distinct offerings being presented as one. The naming came from an internal competition among the team. Having distinct sub-brand names allowed each to speak clearly to its specific audience without creating confusion."})}),(0,p.jsxs)("div",{className:"case-image-row",style:{marginTop:"2rem",marginBottom:"2rem",display:"grid",gridTemplateColumns:"1fr 1fr",gap:"20px"},children:[(0,p.jsxs)("figure",{className:"case-figure",children:[(0,p.jsx)(f,{src:"/images/nowpurchase-website/brainstorm-1.png",alt:"Strategy workshop with the team",className:"case-visual"}),(0,p.jsx)("figcaption",{children:"Strategy workshop — aligning on content and brand direction"})]}),(0,p.jsxs)("figure",{className:"case-figure",children:[(0,p.jsx)(f,{src:"/images/nowpurchase-website/brainstorm-2.png",alt:"1-on-1 stakeholder discussion",className:"case-visual"}),(0,p.jsx)("figcaption",{children:"1-on-1 stakeholder session — defining the sub-brand strategy"})]})]}),(0,p.jsxs)("div",{className:"strategy-grid",children:[(0,p.jsxs)("div",{className:"strategy-card strategy-card--marketplace fade-up-child",children:[(0,p.jsx)("span",{className:"strategy-tag",children:"NOWPURCHASE MARKETPLACE"}),(0,p.jsx)("h3",{children:"A procurement platform for raw material buyers."}),(0,p.jsxs)("p",{children:[(0,p.jsx)("strong",{children:"Core value:"})," Optimise raw material supply chain for timely, high-quality delivery. Explore different alloys to add value to procurement. Develop a sustainable scrap ecosystem. Analyse procurement data at a granular level. Aim to make India the largest supplier in the market."]})]}),(0,p.jsxs)("div",{className:"strategy-card strategy-card--metalcloud fade-up-child",children:[(0,p.jsx)("span",{className:"strategy-tag",children:"NOWPURCHASE METALCLOUD"}),(0,p.jsx)("h3",{children:"A SaaS platform for foundry operations."}),(0,p.jsxs)("p",{children:[(0,p.jsx)("strong",{children:"Core value:"})," Real-time updates to foundries to optimise workflows and ensure timely delivery. Identify patterns and trends to increase efficiency. Save costs and improve casting quality with precise control over melting processes. Determine optimal combination of raw materials for desired alloys at lowest cost and highest efficiency."]})]})]}),(0,p.jsxs)("div",{className:"case-body",children:[(0,p.jsx)("p",{children:"The naming came from an internal competition among the team. Having distinct sub-brand names — NP MarketPlace and NP MetalCloud — allowed each to speak clearly to its specific audience without creating confusion."}),(0,p.jsx)("p",{children:"We structured the entire website using the Why-How-What sales funnel model: start with why NowPurchase exists, move to how it delivers value, then what it specifically offers. This gave every page section a clear job to do. The naming came from an internal competition among the team. Having distinct sub-brand names — NowPurchase MarketPlace and NowPurchase MetalCloud — allowed each to speak clearly to its specific audience without creating confusion."})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--bg fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"From research to information architecture to high-fidelity UI."}),(0,p.jsx)("div",{className:"case-body",children:(0,p.jsx)("p",{children:"With the content strategy locked, I moved into design. The process: Information Architecture → Wireframes → Visual Design → Prototype → Usability Testing."})}),(0,p.jsxs)("div",{className:"design-subsection",children:[(0,p.jsx)("h3",{children:"Information Architecture"}),(0