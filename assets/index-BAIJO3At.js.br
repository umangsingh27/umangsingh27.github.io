0,p.jsx)("p",{className:"impact-stat-metric",children:"days from audit to component launch"}),(0,p.jsx)("p",{className:"impact-stat-target",children:"On schedule"})]})]}),(0,p.jsxs)("div",{className:"impact-narrative",children:[(0,p.jsx)("h3",{children:"What Shipped"}),(0,p.jsx)("p",{children:"Before this system existed, NowPurchase and MetalCloud had no shared design language — two separate product teams were independently solving the same layout, component, and pattern problems. Every new screen meant starting from scratch."}),(0,p.jsx)("p",{children:"We built a complete Atomic Design System from the ground up: colour tokens across 7 palettes with 11-step scales, a full typography system, spacing and border tokens, a unified icon library, and a component library covering Sub-atoms through to full Pages."}),(0,p.jsx)("p",{children:"The system is now live and actively being adopted by both the Design and Development teams across MetalCloud and NowPurchase."})]}),(0,p.jsxs)("div",{className:"impact-outcomes",children:[(0,p.jsxs)("div",{className:"outcome-card fade-up-child",children:[(0,p.jsx)("h4",{children:"Speed"}),(0,p.jsx)("p",{children:"Design-to-dev handoff that previously required extensive back-and-forth — clarifying colours, spacing, states — now references a single source of truth. Target: 30% reduction in handoff time within 6 months of full adoption."})]}),(0,p.jsxs)("div",{className:"outcome-card fade-up-child",children:[(0,p.jsx)("h4",{children:"Consistency"}),(0,p.jsx)("p",{children:"Landing pages, dashboards, detail views, empty states, and creation flows — all previously built with diverging patterns — now follow a unified language. Target: 50% fewer inconsistency-related bugs and rework cycles within 6 months."})]}),(0,p.jsxs)("div",{className:"outcome-card fade-up-child",children:[(0,p.jsx)("h4",{children:"Focus"}),(0,p.jsx)("p",{children:"By removing repetitive UI decision-making from both designers and developers, the team can now spend meaningful time on product thinking and user problems — not redrawing buttons."})]})]}),(0,p.jsx)("div",{className:"designer-reflection",children:(0,p.jsxs)("blockquote",{children:[(0,p.jsx)("p",{children:'"The hardest part wasn\'t building the components — it was building the case for why the system needed to exist before anyone would invest time in it. The ROI presentation showing Rs. 2,05,000 in savings per feature launch was what got the team aligned. As a designer, learning to speak in business terms — not just design terms — was the real unlock."'}),(0,p.jsx)("p",{className:"reflection-attribution",children:"— Umang Singh, Lead UX/UI Designer"})]})}),(0,p.jsxs)("div",{className:"impact-footer",children:[(0,p.jsxs)("div",{className:"status-section",children:[(0,p.jsx)("p",{className:"status-badge",children:"In Progress · Implementation rolling out over 3 months"}),(0,p.jsx)("p",{className:"maintenance-note",children:"Long-term governance led by the design team lead"})]}),(0,p.jsx)("a",{href:"https://www.figma.com/design/JAwKifrBtSKtk2z4DexTa8/Other?node-id=49-5020",target:"_blank",rel:"noopener noreferrer",className:"btn btn--primary",children:"View Design System in Figma →"})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsx)("div",{className:"case-section__inner",children:(0,p.jsxs)("div",{className:"next-project",children:[(0,p.jsx)("span",{className:"next-project__label",children:"END OF CASE STUDY"}),(0,p.jsx)(c,{to:"/work",className:"next-project__link",children:"← Back to Work"})]})})})]})}function C(){return(0,d.useEffect)(()=>{document.title="MetalCloud Platform — Umang Singh"},[]),x(),v(.3),(0,p.jsxs)("main",{className:"metalcloud-case-study",children:[(0,p.jsx)("section",{className:"case-hero fade-up",children:(0,p.jsxs)("div",{className:"case-hero__inner",children:[(0,p.jsx)("span",{className:"case-hero__tag",children:"B2B SAAS · ENTERPRISE"}),(0,p.jsx)("h1",{children:"MetalCloud Platform"}),(0,p.jsx)("p",{className:"case-hero__subtitle",children:"Digitising India's $19 billion foundry industry — from paper records and gut instinct to Internet of Things-connected, Artificial Intelligence-powered manufacturing intelligence."}),(0,p.jsxs)("div",{className:"case-metadata-grid",children:[(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"My Role"}),(0,p.jsx)("p",{children:"Lead User Experience/User Interface Designer & Project Head"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Team"}),(0,p.jsx)("p",{children:"4 Members"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Timeline"}),(0,p.jsx)("p",{children:"45 days (Spectro Pro) · 30 days (Optimise)"})]}),(0,p.jsxs)("div",{className:"metadata-item fade-up-child",children:[(0,p.jsx)("h3",{children:"Tools"}),(0,p.jsx)("p",{children:"FigJam · Figma · Clarity · Amplitude · Google Analytics · Notion"})]})]}),(0,p.jsx)("div",{className:"case-hero__visual",children:(0,p.jsx)(f,{src:"/images/metalcloud/spectro-hero.png",alt:"MetalCloud Spectro Pro — Dashboard, Smart View shop floor display, and WhatsApp alerts",className:"case-visual case-visual--hero",priority:!0})})]})}),(0,p.jsx)("section",{className:"case-section case-section--dark context-dark fade-up","data-theme":"dark",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{className:"context-heading",children:"India's foundries run on paper and instinct."}),(0,p.jsxs)("div",{className:"context-body",children:[(0,p.jsx)("p",{className:"context-paragraph",children:"India's $19B metal manufacturing sector — foundries — rely on paper records, Excel sheets, and decades of accumulated gut instinct to run production. A foundry takes raw materials, melts them in a furnace, analyses the molten metal's chemistry using a spectrometer, manually calculates how to adjust the mix, and pours it into moulds."}),(0,p.jsx)("p",{className:"context-paragraph",children:"Every step in this chain was manual, time-consuming, and error-prone. NowPurchase's MetalCloud platform was already helping foundries with procurement — but the shop floor itself was still analogue."}),(0,p.jsx)("p",{className:"context-paragraph",children:"I was brought in to design two new modules that would change that."})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"Two separate problems. Both costing foundries money every day."}),(0,p.jsxs)("div",{className:"problems-grid",children:[(0,p.jsxs)("div",{className:"problem-card problem-card--spectro fade-up-child",children:[(0,p.jsx)("h3",{children:"Furnace idle time"}),(0,p.jsx)("span",{className:"problem-label",children:"SPECTRO PRO"}),(0,p.jsx)("p",{children:"After each melt, a bath sample is taken to a spectrometer for chemical analysis. The printed report is hand-carried to the melting supervisor, who manually calculates the addition/dilution and relays instructions back to the floor. During all of this — the furnace sits idle, burning energy."}),(0,p.jsxs)("div",{className:"problem-metric",children:[(0,p.jsxs)("p",{children:[(0,p.jsx)("strong",{children:"Current reality:"})," 36 heats/day at ~40 min each"]}),(0,p.jsxs)("p",{children:[(0,p.jsx)("strong",{children:"Potential:"})," 41 heats/day at ~35 min each"]}),(0,p.jsx)("p",{className:"problem-impact",children:"20% opportunity for cost saving (approx)"})]})]}),(0,p.jsxs)("div",{className:"problem-card problem-card--optimise fade-up-child",children:[(0,p.jsx)("h3",{children:"ChargeMix inaccuracy"}),(0,p.jsx)("span",{className:"problem-label",children:"OPTIMISE"}),(0,p.jsx)("p",{children:"Every heat requires a ChargeMix — a precise recipe of raw materials (quantities of scrap, alloys, additives) to achieve target metal chemistry. Foundries were building these manually on paper or Excel, without considering real-time raw material prices, and with no safeguard against human calculation errors."}),(0,p.jsx)("div",{className:"problem-metric",children:(0,p.jsx)("p",{className:"problem-impact",children:"12% opportunity for cost saving (approx)"})})]})]})]})}),(0,p.jsx)("section",{className:"case-section case-section--bg fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"The same 8-step process, applied to both modules."}),(0,p.jsx)("div",{className:"process-timeline",children:["Understand the Existing System","Define the System","Identify Opportunities","Ideate for Solution","Create Designs & Develop","Usability Testing & Launch","Product Updates","Impact Showcase"].map((e,s)=>(0,p.jsxs)("div",{className:"process-step",children:[(0,p.jsx)("div",{className:"process-step__number",children:s+1}),(0,p.jsx)("p",{className:"process-step__label",children:e})]},s))}),(0,p.jsx)("p",{className:"process-note",children:(0,p.jsx)("em",{children:"Both Spectro Pro and Optimise followed this process independently. What's described below is the combined journey."})})]})}),(0,p.jsx)("section",{className:"case-section case-section--surface fade-up",children:(0,p.jsxs)("div",{className:"case-section__inner",children:[(0,p.jsx)("h2",{children:"We went to the factory floor. Not to a meeting room."}),(0,p.jsxs)("div",{className:"case-body",children:[(0,p.jsx)("p",{children:"Research for both modules started with on-ground visits to foundries. We didn't interview stakeholders in an office — we watched operators work, stood next to spectrometer machines, photographed real ChargeMix boards written in chalk, and observed the exact moment a supervisor got a printed report and started calculating by hand."}),(0,p.jsxs)("div",{className:"case-image-row",children:[(0,p.jsxs)("figure",{className:"case-figure",children:[(0,p.jsx)(f,{src:"/images/metalcloud/spectro-machine.png",alt:"Metavision 1008i spectrometer machine at an In